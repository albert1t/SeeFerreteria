# Frontend environment variables
# URL del backend en producción (vacío en desarrollo local usa el proxy de Vite)
VITE_API_URL=

# Opcional: habilita inicio de sesión con Microsoft usando MSAL.
VITE_AZURE_AD_CLIENT_ID=tu-client-id
VITE_AZURE_AD_TENANT_ID=tu-tenant-id
VITE_MSAL_REDIRECT_URI=http://localhost:5173

# Azure Blob Storage — SAS URL del container (incluye el token SAS)
VITE_AZURE_BLOB_SAS_URL=https://<cuenta>.blob.core.windows.net/<container>?<sas-token>
