# Backend environment variables
AZURE_SQL_SERVER=tu-servidor.database.windows.net
AZURE_SQL_DATABASE=see_ferreteria
AZURE_SQL_USER=tu_usuario
AZURE_SQL_PASSWORD=tu_contraseña
AZURE_SQL_ENCRYPT=true
AZURE_SQL_TRUST_SERVER_CERTIFICATE=false
JWT_SECRET=un-secreto-muy-largo-minimo-32-caracteres
JWT_EXPIRES_IN=8h
CORS_ORIGIN=http://localhost:5173
AZURE_BLOB_SAS_URL=https://<cuenta>.blob.core.windows.net/<container>?<sas-token>

# Opcional para Microsoft login (MSAL)
AZURE_AD_TENANT_ID=tu-tenant-id
AZURE_AD_CLIENT_ID=tu-client-id
