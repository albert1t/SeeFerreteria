DirectoryIndex dist/index.html
Options -Indexes

RewriteEngine On

# Redirect API requests to PHP proxy (same-origin, no CORS needed)
RewriteRule ^api/ api/index.php [L,QSA]

# Skip all dist/ assets
RewriteRule ^dist/ - [L]

# Route everything else to the SPA
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ dist/index.html [L]