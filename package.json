{
  "name": "see-ferreteria",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:backend": "npm run dev --prefix backend",
    "dev:all": "concurrently \"npm run dev:backend\" \"npm run dev\"",
    "swa": "swa start --config swa-cli.config.json --config-name dev",
    "build": "tsc -b && vite build",
    "build:backend": "npm run build --prefix backend",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@azure/msal-browser": "^5.12.0",
    "@tanstack/react-query": "^5.69.0",
    "@zxing/browser": "^0.1.5",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.4.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.1.2",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "xlsx": "^0.18.5"
